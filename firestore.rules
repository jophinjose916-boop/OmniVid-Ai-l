rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * OmniVid AI Security Rules
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model. Every piece of data is cryptographically 
     * tied to a specific Firebase Authentication UID. Access is granted based on the relationship 
     * between the authenticated requester and the document's location in the hierarchy.
     * 
     * Data Structure:
     * Data is organized hierarchically under /user_profiles/{userId}. 
     * - User profiles are stored at the root of this tree.
     * - Videos are stored as a subcollection of the specific user who generated them.
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: Rules rely on path wildcards ({userId}) and denormalized fields 
     *    (userProfileId) to make decisions without requiring expensive get() calls to other documents.
     * 2. Structural Segregation: By nesting videos under users, we ensure that listing videos 
     *    is automatically scoped to the owner's data, preventing cross-user data leakage.
     * 3. Prototyping Flexibility: While ownership is strictly enforced, the internal schema of 
     *    documents (except for critical ID fields) is not validated to allow for rapid iteration.
     * 
     * Denormalization for Authorization:
     * - UserProfile documents contain an 'id' field that must match the document ID.
     * - Video documents contain a 'userProfileId' field that must match the parent user's ID.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user is the owner and the document already exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity. Users can only manage their own profile.
     * @path /user_profiles/{userId}
     * @allow (create) If authenticated UID matches {userId} and data.id matches {userId}.
     * @deny (list) If a user attempts to list all profiles.
     * @principle Restricts access to a user's own data tree and enforces relational integrity.
     */
    match /user_profiles/{userId} {
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId) 
                    && request.resource.data.id == userId;
      
      allow update: if isExistingOwner(userId) 
                    && request.resource.data.id == resource.data.id;
      
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for the Video entity. Nested under the owner for structural security.
       * @path /user_profiles/{userId}/videos/{videoId}
       * @allow (get) If the authenticated UID matches the {userId} in the path.
       * @deny (create) If the userProfileId in the data does not match the {userId} in the path.
       * @principle Enforces document ownership for writes and leverages path-based authorization for lists.
       */
      match /videos/{videoId} {
        allow get, list: if isOwner(userId);
        
        allow create: if isOwner(userId) 
                      && request.resource.data.userProfileId == userId;
        
        allow update: if isExistingOwner(userId) 
                      && request.resource.data.userProfileId == resource.data.userProfileId;
        
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}