/**
 * OmniVid AI - Firestore Security Rules
 * 
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Access to data is tied directly to the 
 * user's Firebase Authentication UID, which must match the document path.
 * 
 * Data Structure:
 * - All user data is nested under /users/{userId}.
 * - User profiles: /users/{userId}
 * - User-generated videos: /users/{userId}/videos/{videoId}
 * 
 * Key Security Decisions:
 * - Private Access: There is no public reading or listing of user profiles or videos. 
 * - Path-Based Authorization: The UID in the path acts as the primary authority.
 * - Relational Integrity: On creation, documents must contain fields (like userId) that 
 *   match the path, ensuring that if a document is ever moved or queried outside of 
 *   the path context, its ownership remains clear.
 * - Prototyping Flexibility: Rules prioritize authorization (who can access) over schema 
 *   validation (data types), allowing for rapid application iteration.
 * 
 * Denormalization for Authorization:
 * - The Video document includes a denormalized `userId` field. This allows rules to 
 *   verify ownership by comparing the internal field with the path wildcard and the 
 *   auth token without needing to perform a get() on the parent User document.
 * 
 * Structural Segregation:
 * - User-specific content is strictly segregated into subcollections, preventing cross-user 
 *   data leaks during listing operations.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /**
     * Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId wildcard.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Validates ownership and ensures the document exists for state-changing operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profile documents.
     * @path /users/{userId}
     * @allow Authenticated user (get, list, create, update, delete) if their UID matches the path {userId}.
     * @deny Any request where request.auth.uid does not match the {userId} in the path.
     * @principle Restricts access to a user's own data tree and validates relational integrity.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for videos generated by a specific user.
       * @path /users/{userId}/videos/{videoId}
       * @allow User (create) if path userId matches auth UID and internal userId field matches path.
       * @deny User (update) if they attempt to change the userId or id fields.
       * @principle Enforces path-based ownership and ensures denormalized identity fields are immutable.
       */
      match /videos/{videoId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == videoId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.id == resource.data.id;
        allow delete: if isExistingOwner(userId);
      }
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}