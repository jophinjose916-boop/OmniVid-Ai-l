rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * OmniVid AI Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model. Every piece of data in the system
     * is explicitly tied to a specific user account. Access is governed by the relationship
     * between the authenticated user's UID and the path/content of the document.
     *
     * DATA STRUCTURE:
     * The database is organized hierarchically under the `/users` collection.
     * - `/users/{userId}`: Root profile for a specific user.
     * - `/users/{userId}/videos/{videoId}`: Private video generation data owned by the user.
     *
     * KEY SECURITY DECISIONS:
     * 1. Path-Based Authorization: We rely heavily on the document path wildcards (e.g., {userId})
     *    matching the `request.auth.uid`. This provides high performance and clarity.
     * 2. Denormalization for Integrity: Documents contain internal fields like `userId` or `id`
     *    that must match the path parameters. This ensures that even if a document is moved or
     *    queried out of context, its ownership remains auditable and consistent.
     * 3. Prototyping Flexibility: While ownership is strictly enforced, the schema of content 
     *    fields (like prompts or URLs) is not validated to allow for rapid UI/UX iteration.
     * 4. No Public Access: By default, no data is readable or writeable by unauthenticated users
     *    or by other authenticated users.
     */

    // --- Global Helper Functions ---

    /** Checks if the request is made by an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user matches the provided userId from the path. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Verifies ownership and ensures the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User entity, representing the core profile of a person.
     * @path /users/{userId}
     * @allow (get) If the authenticated UID matches the {userId} wildcard.
     * @deny (list) Global listing of users is prohibited to protect privacy.
     * @principle Restricts access to a user's own data tree and enforces self-creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot browse other users
      
      allow create: if isOwner(userId) 
                    && request.resource.data.id == userId;
      
      allow update: if isExistingOwner(userId) 
                    && request.resource.data.id == resource.data.id;
      
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for the Video entity, representing AI-generated video metadata.
       * @path /users/{userId}/videos/{videoId}
       * @allow (list) If the user is listing documents within their own subcollection.
       * @deny (create) If the internal userId field does not match the path owner.
       * @principle Path-based ownership combined with relational integrity validation.
       */
      match /videos/{videoId} {
        allow get, list: if isOwner(userId);

        allow create: if isOwner(userId)
                      && request.resource.data.userId == userId
                      && request.resource.data.id == videoId;

        allow update: if isExistingOwner(userId)
                      && request.resource.data.userId == resource.data.userId
                      && request.resource.data.id == resource.data.id;

        allow delete: if isExistingOwner(userId);
      }
    }

  }
}