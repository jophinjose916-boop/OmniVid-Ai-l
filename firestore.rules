rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * OmniVid AI Security Rules
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model. All data is scoped to a specific 
     * user and is only accessible by that authenticated user.
     * 
     * Data Structure:
     * The database is organized hierarchically:
     * - /users/{userId}: Private profile information for each user.
     * - /users/{userId}/videos/{videoId}: Private video generation data belonging to the user.
     * 
     * Key Security Decisions:
     * - Authorization Independence: User IDs are denormalized into every document (e.g., 'userId' field).
     *   This allows rules to verify ownership by comparing the auth UID against both the path 
     *   parameter and the document data without performing extra lookups (get() calls).
     * - Denied Public Access: No data in this application is public. All read and write 
     *   operations require a valid session where the UID matches the resource owner.
     * - Structural Segregation: Private user content is nested under the user's root document, 
     *   ensuring that list operations are naturally restricted to the owner's data tree.
     */

    // --- Helper Functions ---

    /** 
     * @description Checks if the request is from a signed-in user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Verifies ownership and ensures the document exists for state-changing operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity. Restricts access to the owner of the profile.
     * @path /users/{userId}
     * @allow (get) request.auth.uid == 'user_123' requesting /users/user_123
     * @deny (list) request.auth.uid == 'user_123' requesting /users (User listing is forbidden)
     * @principle Enforces strict path-based and data-based ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted for security/privacy.
      
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for the Video entity. Nested under the user who created it.
       * @path /users/{userId}/videos/{videoId}
       * @allow (create) request.auth.uid == 'user_123' creating /users/user_123/videos/vid_456
       * @deny (update) request.auth.uid == 'user_123' attempting to change the 'userId' field
       * @principle Validates relational integrity by ensuring the internal userId matches the path owner.
       */
      match /videos/{videoId} {
        allow get, list: if isOwner(userId);
        
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    // Global deny-all fallback
    match /{path=**} {
      allow read, write: if false;
    }
  }
}