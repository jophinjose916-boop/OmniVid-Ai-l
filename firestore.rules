rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * OmniVid AI Security Rules
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a strict user-ownership model. Every piece of data is either 
     * a user profile or a video generated by a specific user. Access is strictly scoped 
     * to the owner identified by their Firebase Authentication UID.
     * 
     * DATA STRUCTURE:
     * - /users/{userId}: Root profile for each user.
     * - /users/{userId}/videos/{videoId}: User-specific subcollection for generated content.
     * 
     * KEY SECURITY DECISIONS:
     * - Authorization Independence: Ownership is verified both by the document path and 
     *   by a denormalized 'userId' field within video documents. This allows for fast, 
     *   non-blocking security checks without cross-document lookups.
     * - Privacy: Listing of the root 'users' collection is disabled to prevent user enumeration.
     * - Immutability: Relational fields like 'userId' are enforced as immutable after creation 
     *   to prevent ownership transfer or data corruption.
     * - Prototyping Flexibility: While authorization is strictly enforced, specific data types 
     *   and content fields are not validated to allow for rapid schema iteration.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /**
     * @description Checks if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @param userId The UID to check against the authenticated user.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Combines ownership check with a check for document existence.
     * Used for update and delete operations to prevent actions on non-existent data.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the User entity, representing individual user profiles.
     * @path /users/{userId}
     * @allow (get) If the request.auth.uid matches {userId}.
     * @deny (list) Requests to list all users are always rejected.
     * @principle Enforces path-based ownership for profile data and prevents user listing.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for the Video entity, representing AI-generated videos.
       * @path /users/{userId}/videos/{videoId}
       * @allow (create) If user is owner and data.userId matches the path.
       * @deny (update) If the attempt tries to change the owning userId.
       * @principle Uses denormalized ownership fields to ensure authorization independence.
       */
      match /videos/{videoId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}